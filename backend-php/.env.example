# TrainerMentors Environment Configuration
# Copy this to .env and fill in your actual values

# Application
APP_ENV=production
APP_NAME=TrainerMentors
APP_TIMEZONE=Asia/Kolkata

# Database
DB_HOST=localhost
DB_NAME=trainermentors_db
DB_USER=u123456789_trainermentors
DB_PASS=your_database_password

# API
API_BASE_URL=https://trainermentors.com/api
FRONTEND_URL=https://trainermentors.com

# JWT
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# Google Identity Services — must match frontend VITE_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=995087720646-vfe3ji6thpfnf2jika9vfq0blescmr0g.apps.googleusercontent.com

# Email
EMAIL_FROM=noreply@trainermentors.com
ADMIN_EMAIL=admin@trainermentors.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Payment Gateway
RAZORPAY_KEY=rzp_live_xxxxx
RAZORPAY_SECRET=xxxxx
UPI_ID=your-upi-id@bank
UPI_MERCHANT_NAME=TrainerMentors
