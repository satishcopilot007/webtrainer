# TrainerMentors Frontend Configuration
# Copy this file to .env.local and update with your actual values

# API Configuration
VITE_API_URL=http://localhost:8000/api
VITE_API_TIMEOUT=30000

# UPI Direct Payment (shown as QR on checkout page)
# This is read server-side only; frontend fetches from /api/payment/upi-qr
# Set UPI_ID in the root .env file, not here

# Razorpay Payment Gateway
# For PRODUCTION: set your live key (starts with rzp_live_)
# Auto-detected: if key starts with rzp_live_, live mode is enabled automatically
# Get keys from: https://dashboard.razorpay.com → Settings → API Keys
VITE_RAZORPAY_KEY_ID=rzp_test_1Aa00000000001
# VITE_RAZORPAY_KEY_ID=rzp_live_YOUR_ACTUAL_KEY_ID  <-- uncomment for production
VITE_RAZORPAY_TEST_KEY_ID=rzp_test_1Aa00000000001

# Live Chat Integration - Tawk.to (Optional)
VITE_TAWK_PROPERTY_ID=YOUR_TAWK_PROPERTY_ID

# Alternative: Crisp Chat (Optional)
VITE_CRISP_WEBSITE_ID=YOUR_CRISP_ID

# Social Media Links
VITE_WHATSAPP_NUMBER=919999999999
VITE_INSTAGRAM_HANDLE=trainermentors
VITE_FACEBOOK_PAGE=trainermentors
VITE_LINKEDIN_COMPANY=trainermentors
VITE_TWITTER_HANDLE=trainermentors
VITE_YOUTUBE_CHANNEL=@trainermentors
VITE_TELEGRAM_CHANNEL=trainermentors
VITE_GITHUB_PROFILE=trainermentors

# Email Configuration
VITE_CONTACT_EMAIL=contact@trainermentors.com
VITE_SUPPORT_EMAIL=support@trainermentors.com

# Google Analytics (Optional)
VITE_GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Feature Flags
VITE_ENABLE_LIVE_CHAT=true
VITE_ENABLE_RAZORPAY=true
REACT_APP_ENABLE_SOCIAL_SHARING=true
