# ===== TrainerMentors Backend Configuration =====
# Copy this file to .env and update with your actual credentials

# ===== Node Environment =====
NODE_ENV=development
# Options: development, production, staging

# ===== Server Configuration =====
PORT=8000
API_URL=http://localhost:8000

# ===== Frontend Configuration (CORS) =====
FRONTEND_URL=http://localhost:3000
# For production:
# FRONTEND_URL=https://trainermentors.com

# ===== Database Configuration (Optional - for future PostgreSQL/MySQL migration) =====
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=trainermentors
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_SSL=false

# ===== UPI Direct Payment =====
# Your UPI ID (e.g. yourname@centralbank or phone@upi)
# Get this from your Central Bank of India UPI app or BHIM app
UPI_ID=yourname@centralbank
UPI_MERCHANT_NAME=TrainerMentors

# ===== Razorpay Configuration =====
# Test Keys (for development) — works out of the box
RAZORPAY_KEY_ID=rzp_test_1Aa00000000001
RAZORPAY_KEY_SECRET=

# Live Keys — get from https://dashboard.razorpay.com → Settings → API Keys
# Uncomment and fill both for production:
# RAZORPAY_KEY_ID=rzp_live_YOUR_ACTUAL_KEY_ID
# RAZORPAY_KEY_SECRET=YOUR_ACTUAL_KEY_SECRET
# RAZORPAY_MERCHANT_ID=YOUR_MERCHANT_ID

# ===== Email Configuration (Gmail SMTP) =====
# 1. Enable 2FA on Gmail: https://myaccount.google.com/security
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Copy the 16-character password below

EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
SENDER_EMAIL=your-email@gmail.com
SENDER_NAME=TrainerMentors

# ===== Email Features =====
SEND_ENROLLMENT_EMAIL=true
SEND_PAYMENT_EMAIL=true
SEND_WELCOME_EMAIL=true
SEND_DEMO_BOOKING_EMAIL=true

# ===== JWT Configuration =====
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ===== Payment Gateway =====
PAYMENT_GATEWAY=razorpay
# Options: razorpay, paypal, stripe (only razorpay is implemented)

# ===== Tax Configuration =====
TAX_RATE=0.18
TAX_NAME=GST
TAX_ENABLED=true

# ===== Feature Flags =====
ENABLE_COURSE_FILTERING=true
ENABLE_COURSE_SEARCH=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_PAYMENT_PROCESSING=true

# ===== Logging Configuration =====
LOG_LEVEL=debug
# Options: error, warn, info, debug, trace

# ===== File Upload Configuration =====
MAX_FILE_SIZE=10485760
# 10MB in bytes
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx,xls,xlsx

# ===== API Rate Limiting =====
RATE_LIMIT_WINDOW=15
# Minutes
RATE_LIMIT_MAX_REQUESTS=100
# Max requests per window

# ===== Cache Configuration =====
CACHE_ENABLED=true
CACHE_TTL=3600
# Time to live in seconds

# ===== CORS Configuration =====
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
# For production: https://trainermentors.com

# ===== Analytics Configuration (Optional) =====
# GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
# MIXPANEL_TOKEN=your-token

# ===== Webhook Configuration (Optional) =====
# WEBHOOK_URL=https://trainermentors.com/webhooks
# WEBHOOK_SECRET=your-webhook-secret

# ===== Monitoring Configuration (Optional) =====
# SENTRY_DSN=https://xxx@sentry.io/xxx
# NEWRELIC_LICENSE_KEY=your-key

# ===== Session Configuration =====
SESSION_SECRET=your-session-secret-key
SESSION_MAX_AGE=86400000
# 24 hours in milliseconds
